{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "lekiwi-console",
  "version": "0.1.0",
  "identifier": "com.jatson.lekiwiconsole",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LeKiwi 控制台 · Orin",
        "width": 1280,
        "height": 900,
        "minWidth": 820,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.png"]
  }
}
